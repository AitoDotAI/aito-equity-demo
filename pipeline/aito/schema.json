{
  "_comment": "Aito schema for the companies table. Multi-market columns (market, exchange, currency, reporting_standard, filing_language) and quant-feature columns are included from day 1 so non-US / fundamentals data slots in without migration. All non-key columns are nullable because v1 data is sparse (no fundamentals stage yet; LLM grades only on companies whose filings were retrievable). Keys: ticker + vintage_year.",
  "schema": {
    "companies": {
      "type": "table",
      "columns": {
        "ticker":                       { "type": "String" },
        "vintage_year":                 { "type": "Int" },
        "vintage_date":                 { "type": "String", "nullable": true },
        "company_name":                 { "type": "String", "nullable": true },

        "market":                       { "type": "String", "nullable": true },
        "exchange":                     { "type": "String", "nullable": true },
        "currency":                     { "type": "String", "nullable": true },
        "reporting_standard":           { "type": "String", "nullable": true },
        "filing_language":              { "type": "String", "nullable": true },

        "sector":                       { "type": "String", "nullable": true },
        "industry":                     { "type": "String", "nullable": true },
        "market_cap_bucket":            { "type": "String", "nullable": true },

        "pe_ratio":                     { "type": "Decimal", "nullable": true },
        "pb_ratio":                     { "type": "Decimal", "nullable": true },
        "ev_ebitda":                    { "type": "Decimal", "nullable": true },
        "roic_5y_avg":                  { "type": "Decimal", "nullable": true },
        "gross_margin":                 { "type": "Decimal", "nullable": true },
        "operating_margin":             { "type": "Decimal", "nullable": true },
        "revenue_cagr_5y":              { "type": "Decimal", "nullable": true },
        "debt_to_equity":               { "type": "Decimal", "nullable": true },
        "years_public":                 { "type": "Int", "nullable": true },
        "founder_still_ceo":            { "type": "Boolean", "nullable": true },

        "market_position":              { "type": "String", "nullable": true },
        "moat_type":                    { "type": "String", "nullable": true },
        "moat_strength":                { "type": "String", "nullable": true },
        "market_quality":               { "type": "String", "nullable": true },
        "leadership_quality":           { "type": "Int", "nullable": true },
        "capital_allocation":           { "type": "Int", "nullable": true },
        "strategic_clarity":            { "type": "Int", "nullable": true },
        "execution_track_record":       { "type": "Int", "nullable": true },

        "market_position_rationale":    { "type": "Text", "analyzer": "english", "nullable": true },
        "moat_rationale":               { "type": "Text", "analyzer": "english", "nullable": true },
        "market_quality_rationale":     { "type": "Text", "analyzer": "english", "nullable": true },
        "leadership_rationale":         { "type": "Text", "analyzer": "english", "nullable": true },

        "outcome_bucket":               { "type": "String", "nullable": true },
        "survived_intact":              { "type": "Boolean", "nullable": true },
        "terminal_event":               { "type": "String", "nullable": true },
        "total_return_pct_local":       { "type": "Decimal", "nullable": true },
        "total_return_pct_usd":         { "type": "Decimal", "nullable": true },
        "window_years":                 { "type": "Decimal", "nullable": true }
      }
    }
  }
}
