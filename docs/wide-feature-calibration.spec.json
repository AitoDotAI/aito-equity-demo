  "model": {
    "flat_nb": {
      "alpha_laplace": 1.0,
      "structure": "P(y) * prod_f P(f|y)"
    },
    "clustered_nb": {
      "alpha_laplace": 1.0,
      "theme_encoder": "per multi-feature cluster: score each value by mean outcome-rank on the TRAIN fold (target encoding), average member scores per row, quantise into n_levels bins by train quantiles \u2192 one ordinal theme variable. Singletons pass through unchanged.",
      "n_levels": 4,
      "predict_beta0": "P(y) * prod_themes P(theme|y)   # one decorrelated vote per cluster",
      "predict_beta_residual": "+ beta * sum_{f in multi-cluster} log[P(f|theme,y)/P(f|theme)]   # WARNING: this formulation re-injects an outcome vote and WORSENS calibration. The intended nuance must refine the THEME assignment, not add a parallel outcome vote. Open design question (see open_questions)."
    }
  },
