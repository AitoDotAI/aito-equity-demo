  "clustering_algorithm": {
    "type": "agglomerative, complete-linkage, MDL + NMI-floor stop",
    "merge_rule": "merge the cluster pair with the highest min-cross-pair NMI, provided (a) min-cross-pair MDL gain > 0 AND (b) min-cross-pair NMI >= min_nmi; stop when no pair qualifies",
    "mdl_gain": "N*I(X;Y)/ln(2) - 0.5*(|X|-1)*(|Y|-1)*log2(N)   # bits saved \u2212 BIC table cost",
    "min_nmi_is_resolution_knob": true,
    "note_bic_too_weak": "At N~1300 pure BIC-MDL under-penalises (tiny MI pervades all features) and cascades into one mega-cluster; the NMI floor controls resolution. aito-core may prefer a predictor-aware description length instead.",
