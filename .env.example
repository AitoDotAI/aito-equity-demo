# Copy to .env and fill in values. .env is gitignored.

# ── Aito predictive database (needed for load + precompute stages) ──
# Pipeline writes rows here and queries _predict / _relate / _match.
AITO_API_URL=https://shared.aito.ai/db/your-db-here
AITO_API_KEY=your-read-write-key-here

# ── Azure OpenAI (needed for LLM extraction stage) ──────────────────
# Used by `./do pipeline extract` to grade qualitative features from
# 10-K and DEF 14A filings. v1 deployment: gpt-5-mini.
OPENAI_MODEL_URL="https://<resource>.api.cognitive.microsoft.com"
OPENAI_MODEL_API_KEY=...
OPENAI_MODEL_DEPLOYMENT=gpt-5-mini
OPENAI_MODEL_API_VERSION=2024-08-01-preview
# Informational (not read by the client): OPENAI_RESOURCE_NAME, OPENAI_MODEL_NAME

# ── EDGAR fetcher (needed for `./do pipeline filings`) ──────────────
# SEC EDGAR requires a real User-Agent with contact email. The default
# in pipeline/filings/edgar.py works; override here if you forked.
# EDGAR_USER_AGENT="Your Org Name you@example.com"
